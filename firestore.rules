rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userDocExists() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function getUserRole() {
      return userDocExists() ? getUserData().role : '';
    }

    function hasRole(role) {
      return isSignedIn() && userDocExists() && getUserData().role == role;
    }

    function isOrganizer() {
      return isSignedIn() && userDocExists() &&
        (getUserData().role == 'Organizer' || getUserData().role == 'organizer');
    }

    function isChair() {
      return isSignedIn() && userDocExists() &&
        (getUserData().role == 'Chair' || getUserData().role == 'chair');
    }

    function isAdmin() {
      return isSignedIn() && userDocExists() &&
        (getUserData().role == 'App Admin' || getUserData().role == 'admin' || getUserData().isAdmin == true);
    }

    function isEventOrganizer(eventId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/events/$(eventId)).data.organizerId == request.auth.uid;
    }

    match /{path=**}/results/{resultId} {
      allow read: if isSignedIn();
    }

    // ── User Profiles ──────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isSignedIn() && (
        request.auth.uid == userId ||
        !('privacySettings' in resource.data) ||
        !('showProfile' in resource.data.privacySettings) ||
        resource.data.privacySettings.showProfile != false
      );
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if request.auth.uid == userId || isAdmin();
      allow delete: if isAdmin();

      match /blocks/{blockedUid} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }

      match /connections/{otherUid} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // ── Pro Applications ───────────────────────────────────────────────────────
    match /proApplications/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    // ── Events ────────────────────────────────────────────────────────────────
    match /events/{eventId} {
      allow read: if true;
      allow create: if isOrganizer() || isAdmin() ||
        (isSignedIn() && request.resource.data.organizerId == request.auth.uid);
      allow update, delete: if isSignedIn() &&
        (resource.data.organizerId == request.auth.uid || isAdmin());

      match /staff/{uid} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() &&
          (get(/databases/$(database)/documents/events/$(eventId)).data.organizerId == request.auth.uid || isAdmin());
      }

      match /partners/{partnerId} {
        allow read: if true;
        allow write: if isSignedIn() &&
          (get(/databases/$(database)/documents/events/$(eventId)).data.organizerId == request.auth.uid || isAdmin());
      }

      // Announcements — delegates can read sent/queued announcements
      match /announcements/{announcementId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() &&
          (get(/databases/$(database)/documents/events/$(eventId)).data.organizerId == request.auth.uid || isAdmin());
      }

      match /waitlist/{entryId} {
        allow read: if isSignedIn() &&
          (get(/databases/$(database)/documents/events/$(eventId)).data.organizerId == request.auth.uid || isAdmin());
        allow write: if isSignedIn() &&
          (get(/databases/$(database)/documents/events/$(eventId)).data.organizerId == request.auth.uid || isAdmin());
      }

      match /results/{resultId} {
        allow read: if isSignedIn();
        allow create: if isChair() || isOrganizer() || isAdmin() ||
          (isSignedIn() && get(/databases/$(database)/documents/events/$(eventId)).data.organizerId == request.auth.uid);
        allow update: if isSignedIn() &&
          (get(/databases/$(database)/documents/events/$(eventId)).data.organizerId == request.auth.uid || isAdmin() || isChair());
      }

      // Food slots — organizer writes, signed-in reads
      match /foodSlots/{slotId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() &&
          (get(/databases/$(database)/documents/events/$(eventId)).data.organizerId == request.auth.uid || isAdmin());
      }

      // Transport routes — organizer writes, signed-in reads; delegates can self-register
      match /transportRoutes/{routeId} {
        allow read: if isSignedIn();
        allow create, delete: if isSignedIn() &&
          (get(/databases/$(database)/documents/events/$(eventId)).data.organizerId == request.auth.uid || isAdmin());
        allow update: if isSignedIn();
      }

      // Accommodation blocks — organizer writes, signed-in reads
      match /accommodationBlocks/{blockId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() &&
          (get(/databases/$(database)/documents/events/$(eventId)).data.organizerId == request.auth.uid || isAdmin());
      }

      // Accommodation requests — delegate creates/reads own, organizer manages all
      match /accommodationRequests/{reqId} {
        allow read: if isSignedIn() && (
          resource.data.delegateUid == request.auth.uid ||
          get(/databases/$(database)/documents/events/$(eventId)).data.organizerId == request.auth.uid ||
          isAdmin()
        );
        allow create: if isSignedIn();
        allow update: if isSignedIn() && (
          get(/databases/$(database)/documents/events/$(eventId)).data.organizerId == request.auth.uid || isAdmin()
        );
      }

      // Live sessions — organizer writes, signed-in reads
      match /liveSessions/{sessionId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() &&
          (get(/databases/$(database)/documents/events/$(eventId)).data.organizerId == request.auth.uid || isAdmin());
      }

      // Study guides — chair or organizer writes, delegates read
      match /studyGuides/{committeeName} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() &&
          (get(/databases/$(database)/documents/events/$(eventId)).data.organizerId == request.auth.uid ||
           isChair() || isAdmin());
      }

      // Committee notifications (room alerts) — chair writes, delegates read
      match /committees/{committeeId}/notifications/{notifId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && (isChair() || isOrganizer() || isAdmin() ||
          get(/databases/$(database)/documents/events/$(eventId)).data.organizerId == request.auth.uid);
        allow delete: if isSignedIn() &&
          (get(/databases/$(database)/documents/events/$(eventId)).data.organizerId == request.auth.uid ||
           isChair() || isAdmin());
      }
    }

    // ── Applications ──────────────────────────────────────────────────────────
    match /applications/{appId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.userId ||
        isOrganizer() ||
        isChair() ||
        isAdmin() ||
        (get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.organizerId == request.auth.uid) ||
        ('institutionName' in resource.data && 'institutionName' in getUserData() && resource.data.institutionName == getUserData().institutionName) ||
        ('delegationId' in resource.data) // Allow reading team members if they share a delegation (simplified for team leads)
      );
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.userId ||
        isOrganizer() ||
        isAdmin() ||
        (get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.organizerId == request.auth.uid)
      );
    }

    // ── Articles ──────────────────────────────────────────────────────────────
    match /articles/{articleId} {
      allow read: if resource.data.published == true || isAdmin() ||
        (isSignedIn() && request.auth.uid == resource.data.authorId);
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() &&
        (request.auth.uid == resource.data.authorId || isAdmin());

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow delete: if isSignedIn() &&
          (request.auth.uid == resource.data.authorId || isAdmin());
      }
    }

    // ── Conversations ─────────────────────────────────────────────────────────
    match /conversations/{convId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && request.auth.uid in resource.data.participants;

      match /messages/{msgId} {
        allow read: if isSignedIn() &&
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
        allow create: if isSignedIn()
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants
          && request.resource.data.senderId == request.auth.uid
          && (!('blockedBy' in get(/databases/$(database)/documents/conversations/$(convId)).data) ||
              !(request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.blockedBy));
      }
    }

    // ── Activities ────────────────────────────────────────────────────────────
    match /activities/{activityId} {
      allow read: if isSignedIn() && (
        resource.data.isPublic == true ||
        resource.data.userId == request.auth.uid
      );
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ── Markings ──────────────────────────────────────────────────────────────
    match /markings/{markingId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.delegateId ||
        isChair() ||
        isOrganizer() ||
        isAdmin()
      );
      allow create, update: if isChair() || isOrganizer() || isAdmin();
    }

    // ── Complaints (with escalation hierarchy) ────────────────────────────────
    match /complaints/{complaintId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.userId ||
        request.auth.uid == resource.data.assignedTo ||
        ('actorUids' in resource.data && request.auth.uid in resource.data.actorUids) ||
        isChair() ||
        isOrganizer() ||
        isAdmin()
      );
      allow create: if isSignedIn();
      // Delegate can update their own (e.g. addendum); chair/organizer/admin can update escalation
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.assignedTo ||
        isOrganizer() ||
        isAdmin()
      );
    }

    // ── Logs ──────────────────────────────────────────────────────────────────
    match /certificateGenerationLogs/{logId} {
      allow read, write: if isAdmin();
    }

    // ── System Settings ───────────────────────────────────────────────────────
    match /systemSettings/{document} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ── Audit Logs ────────────────────────────────────────────────────────────
    match /auditLogs/{logId} {
      allow read, write: if isAdmin();
    }
  }
}

